## Web3Forms — optional email notifications (https://web3forms.com)
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

## MongoDB — form data storage (required for submissions)
## Local: mongodb://127.0.0.1:27017
## Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=db_expo

## API server port (run: npm run dev:api)
API_PORT=3001
